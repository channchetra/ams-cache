{
  "name": "ams-cache",
  "version": "3.0.6",
  "private": true,
  "type": "module",
  "description": "Build tooling and optional local optimizers for the AMS Cache WordPress plugin.",
  "scripts": {
    "dev": "bunx vite --host 127.0.0.1",
    "build": "bunx vite build",
    "build:release": "bun run build && powershell -ExecutionPolicy Bypass -File ./bin/build-release.ps1",
    "release": "powershell -ExecutionPolicy Bypass -File ./bin/release.ps1",
    "release:patch": "powershell -ExecutionPolicy Bypass -File ./bin/release.ps1 -Bump patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File ./bin/release.ps1 -Bump minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File ./bin/release.ps1 -Bump major",
    "image:check": "bun inc/assets/bun/image-optimizer.mjs --check"
  },
  "devDependencies": {
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "4.3.0",
    "tailwind-variants": "^3.2.2",
    "vite": "8.0.14"
  }
}
