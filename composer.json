{
    "name": "ams/ams-cache",
    "description": "AMS Cache is an extremely lightweight, high-performance cache plugin that speeds up your WordPress sites on the fly.",
    "keywords": ["wordpress-plugin", "wordpress-cache", "cache-plugin"],
    "homepage": "https://ams.com.kh/",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Terry Lin",
            "email": "contact@terryl.in",
            "homepage": "https://terryl.in/zh/"
        }
    ],
    "require": {
        "shieldon/simple-cache": "^1.0"
    },
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "post-install-cmd": [
            "@php -r \"copy('patches/File.php', 'vendor/shieldon/simple-cache/src/SimpleCache/Driver/File.php');\"",
            "@php -r \"copy('patches/Redis.php', 'vendor/shieldon/simple-cache/src/SimpleCache/Driver/Redis.php');\""
        ],
        "post-update-cmd": [
            "@php -r \"copy('patches/File.php', 'vendor/shieldon/simple-cache/src/SimpleCache/Driver/File.php');\"",
            "@php -r \"copy('patches/Redis.php', 'vendor/shieldon/simple-cache/src/SimpleCache/Driver/Redis.php');\""
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WpUnit\\": "tests/src"
        }
    }
}
